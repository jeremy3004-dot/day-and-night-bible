{
  "expo": {
    "name": "Day and Night Bible",
    "slug": "day-and-night-bible",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "com.dayandnightbible.app",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#101113"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dayandnightbible.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "UILaunchStoryboardName": "DayAndNightBibleLaunchScreen",
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/monochrome-icon.png",
        "backgroundColor": "#101113"
      },
      "package": "com.dayandnightbible.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-asset",
        {
          "assets": [
            "./assets/databases/bible-bsb-v2.db"
          ]
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-av",
      "@kesha-antonov/react-native-background-downloader",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#8B2635"
        }
      ],
      "expo-image-picker",
      "expo-localization",
      "./plugins/withBrandedSplashAsset",
      "@react-native-google-signin/google-signin"
    ],
    "owner": "jeremy1001",
    "extra": {
      "eas": {
        "projectId": "18d362a1-3c47-45b7-8425-7396fc1c2052"
      }
    }
  }
}
